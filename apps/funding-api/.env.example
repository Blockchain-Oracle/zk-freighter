# Server
PORT=8787
DATABASE_URL=

# Stellar testnet funder. Never use a user wallet seed here.
ZKF_TESTNET_FUNDER_SECRET=

# Funding amounts in decimal asset units.
ZKF_TESTNET_FUND_XLM=25
ZKF_TESTNET_FUND_USDC=5

# Rate limits
ZKF_FUNDING_ADDRESS_LIMIT=3
ZKF_FUNDING_ADDRESS_WINDOW_MS=86400000
ZKF_FUNDING_IP_LIMIT=20
ZKF_FUNDING_IP_WINDOW_MS=86400000

# EVM faucet (Base Sepolia + OP Sepolia). Testnet-only; refuses other chains.
# Never use a user wallet key here.
ZKF_EVM_FUNDER_PRIVATE_KEY=
# USDC in 6-decimal base units (default 10 USDC) and gas in wei (default 0.002 ETH).
ZKF_EVM_FUND_USDC_UNITS=10000000
ZKF_EVM_FUND_GAS_WEI=2000000000000000
# Optional RPC overrides (defaults: https://sepolia.base.org / https://sepolia.optimism.io)
ZKF_EVM_RPC_BASE=
ZKF_EVM_RPC_OPTIMISM=
