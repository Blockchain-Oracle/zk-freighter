# Production service endpoints baked into device builds (APK / IPA / PWA).
# Higher Vite precedence than .env.local, so the native builds ship the hosted
# bootnode/funding URLs instead of a dev LAN IP or the phone's own localhost.
# Without this, a Capacitor webview (which runs on localhost) can't reach the
# pool-event index and shielded balances never sync.
VITE_ZKF_TESTNET_FUNDING_API_URL=https://api.zkfreighter.app
VITE_ZKF_TESTNET_BOOTNODE_URL=https://bootnode.zkfreighter.app/rpc
VITE_ZKF_MAINNET_BOOTNODE_URL=https://mainnet-bootnode.zkfreighter.app/rpc
