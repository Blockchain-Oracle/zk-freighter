# Copy to app/keystore.properties (gitignored) after generating the release
# keystore. build.gradle reads this to sign release builds.
#
# Generate once (needs a JDK / Android Studio), then BACK UP the .keystore file
# and these passwords somewhere safe — losing them means you can never ship an
# update to an already-installed app:
#
#   keytool -genkeypair -v \
#     -keystore app/zkfreighter-release.keystore \
#     -alias zkfreighter -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=zkfreighter-release.keystore
storePassword=CHANGE_ME
keyAlias=zkfreighter
keyPassword=CHANGE_ME
