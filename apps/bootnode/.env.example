# Server
PORT=8788
DATABASE_URL=

# Network and upstream RPC
ZKF_BOOTNODE_NETWORK=testnet
ZKF_BOOTNODE_UPSTREAM_RPC_URL=

# Optional comma-separated pool IDs. Defaults to configured XLM/USDC pools.
ZKF_BOOTNODE_ALLOWED_CONTRACTS=

# Background event warmer. Defaults are network-specific verified deployment ledgers.
# Mainnet warming needs an archive-capable upstream or an already-warmed database.
ZKF_BOOTNODE_INDEXER_ENABLED=true
ZKF_BOOTNODE_START_LEDGER=
ZKF_BOOTNODE_PAGE_SIZE=200
ZKF_BOOTNODE_MAX_PAGES_PER_ROUND=4
ZKF_BOOTNODE_INDEXER_INTERVAL_MS=2000
