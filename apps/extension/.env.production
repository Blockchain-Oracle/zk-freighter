# Production service endpoints baked into the published extension build.
# Higher Vite precedence than .env.local, so `pnpm extension:zip` (production
# mode) always ships the hosted bootnode/funding URLs even if a dev .env.local
# points at localhost. THIS is what makes the Chrome Web Store build reach the
# real pool-event index instead of a developer's laptop.
VITE_ZKF_TESTNET_FUNDING_API_URL=https://api.zkfreighter.app
VITE_ZKF_TESTNET_BOOTNODE_URL=https://bootnode.zkfreighter.app/rpc
VITE_ZKF_MAINNET_BOOTNODE_URL=https://mainnet-bootnode.zkfreighter.app/rpc
