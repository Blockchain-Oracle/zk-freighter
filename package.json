{
  "name": "zk-freighter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "start": "pnpm web:start",
    "dev": "pnpm --filter @zk-freighter/web dev",
    "web:dev": "pnpm --filter @zk-freighter/web dev",
    "web:build": "pnpm --filter @zk-freighter/web build",
    "web:start": "pnpm --filter @zk-freighter/web start",
    "landing:dev": "pnpm --filter @zk-freighter/landing dev",
    "landing:build": "pnpm --filter @zk-freighter/landing build",
    "landing:start": "pnpm --filter @zk-freighter/landing start",
    "docs:dev": "pnpm --filter @zk-freighter/docs dev",
    "docs:build": "pnpm --filter @zk-freighter/docs build",
    "docs:start": "pnpm --filter @zk-freighter/docs start",
    "mobile:dev": "pnpm --filter @zk-freighter/mobile dev",
    "mobile:dev:https": "pnpm --filter @zk-freighter/mobile dev:https",
    "mobile:build": "pnpm --filter @zk-freighter/mobile build",
    "mobile:sync": "pnpm --filter @zk-freighter/mobile sync",
    "mobile:android": "pnpm --filter @zk-freighter/mobile android",
    "mobile:android:build": "pnpm --filter @zk-freighter/mobile android:build",
    "mobile:android:install": "pnpm --filter @zk-freighter/mobile android:install",
    "mobile:ios": "pnpm --filter @zk-freighter/mobile ios",
    "mobile:ios:open": "pnpm --filter @zk-freighter/mobile ios:open",
    "funding-api:dev": "pnpm --filter @zk-freighter/funding-api dev",
    "funding-api:build": "pnpm --filter @zk-freighter/funding-api build",
    "funding-api:start": "pnpm --filter @zk-freighter/funding-api start",
    "bootnode:dev": "pnpm --filter @zk-freighter/bootnode dev",
    "bootnode:dev:mainnet": "pnpm --filter @zk-freighter/bootnode dev:mainnet",
    "bootnode:build": "pnpm --filter @zk-freighter/bootnode build",
    "bootnode:start": "pnpm --filter @zk-freighter/bootnode start",
    "bootnode:start:mainnet": "pnpm --filter @zk-freighter/bootnode start:mainnet",
    "extension:dev": "pnpm --filter @zk-freighter/extension dev",
    "extension:dev:local": "pnpm --filter @zk-freighter/extension dev:local",
    "extension:build": "pnpm --filter @zk-freighter/extension build",
    "extension:build:local": "pnpm --filter @zk-freighter/extension build:local",
    "extension:zip": "pnpm --filter @zk-freighter/extension zip",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint && pnpm docs:check && pnpm files:check && pnpm secrets:check",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run scripts/cctp-bridge-source-support.test.ts && pnpm -r run test",
    "preview": "pnpm --filter @zk-freighter/web preview",
    "prover:stage": "node scripts/stage-nethermind-prover-assets.mjs",
    "testnet-usdc-funder:setup": "node scripts/setup-testnet-usdc-funder.mjs",
    "cctp:bridge:testnet": "ZKF_NETWORK=testnet tsx scripts/check-cctp-bridge-source.ts",
    "cctp:bridge:mainnet": "ZKF_NETWORK=mainnet tsx scripts/check-cctp-bridge-source.ts",
    "cctp:shield:extension": "node scripts/check-extension-cctp-shield.mjs",
    "extension:runtime": "node scripts/check-extension-runtime.mjs",
    "extension:dapp": "node scripts/check-extension-dapp-bridge.mjs",
    "extension:quickshield": "node scripts/check-extension-quickshield.mjs",
    "extension:quickshield:usdc": "ZKF_QUICKSHIELD_ASSET=USDC node scripts/check-extension-quickshield.mjs",
    "extension:private-loop:mainnet": "node scripts/check-mainnet-private-loop.mjs",
    "extension:bridge": "node scripts/check-extension-bridge-handoff.mjs",
    "extension:runtime:deep": "node scripts/check-extension-deep-proof.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "files:check": "node scripts/check-file-size.mjs",
    "secrets:check": "node scripts/secret-scan.mjs"
  },
  "devDependencies": {
    "tsx": "4.22.4",
    "typescript": "~6.0.2",
    "viem": "2.53.1",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "16.0.1"
  }
}
