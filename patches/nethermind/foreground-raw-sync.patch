+
+async fn process_raw_events_until_empty() -> anyhow::Result<()> {
+    const FETCH_LIMIT: u32 = 50;
+
+    loop {
+        let did_raw = with_storage_mut!(s => process_events(s, FETCH_LIMIT)?)?;
+        if !did_raw {
+            break;
+        }
+        // Yield to avoid blocking other worker messages while catching up.
+        gloo_timers::future::TimeoutFuture::new(0).await;
+    }
+    Ok(())
+}
diff --git a/app/crates/platforms/web/src/client/mod.rs b/app/crates/platforms/web/src/client/mod.rs
