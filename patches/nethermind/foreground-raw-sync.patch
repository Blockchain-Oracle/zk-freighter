@@
     pub(super) async fn process_pending_events(&self) -> Result<(), JsError> {
         match self
             .storage_request(StorageWorkerRequest::ProcessPending, 60_000)
             .await?
         {
             StorageWorkerResponse::Saved => Ok(()),
             other => Err(JsError::new(&format!("Unexpected response: {:?}", other))),
         }
     }
+
+    pub(super) async fn process_pending_raw_events(&self) -> Result<(), JsError> {
+        match self
+            .storage_request(StorageWorkerRequest::ProcessRawEvents, 10_000)
+            .await?
+        {
+            StorageWorkerResponse::Saved => Ok(()),
+            other => Err(JsError::new(&format!("Unexpected response: {:?}", other))),
+        }
+    }
@@
     #[wasm_bindgen(js_name = syncPoolEvents)]
     pub async fn sync_pool_events(&self) -> Result<(), JsError> {
@@
         self.process_pending_events().await
     }
+
+    async fn sync_pool_events_for_proving(&self) -> Result<(), JsError> {
+        let indexer = Indexer::init(&self.rpc_url, self.clone(), self.contract_config)
+            .await
+            .map_err(|e| JsError::new(&e.to_string()))?;
+
+        indexer
+            .fetch_contract_events()
+            .await
+            .map_err(|e| JsError::new(&e.to_string()))?;
+        self.process_pending_raw_events().await
+    }
