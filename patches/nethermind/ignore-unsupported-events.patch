+    /// Mark raw events that are intentionally not part of the wallet's local
+    /// state model so the processor does not revisit them forever.
+    pub fn save_ignored_contract_events_batch(
+        &mut self,
+        events: &[(String, String)],
+    ) -> Result<()> {
+        if events.is_empty() {
+            return Ok(());
+        }
+
+        let tx = self.conn.transaction()?;
+        {
+            let mut stmt = tx.prepare(
+                "INSERT INTO ignored_contract_events (event_id, reason)
+                    VALUES (?1, ?2)
+                    ON CONFLICT(event_id) DO UPDATE SET reason = excluded.reason",
+            )?;
+
+            for (event_id, reason) in events {
+                stmt.execute(params![event_id, reason])?;
+            }
+        }
+        tx.commit()?;
+        Ok(())
+    }
