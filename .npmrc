# Include Linux native bindings (rolldown, esbuild, etc.) in the lockfile so
# Coolify/Docker builds on linux-x64 resolve them even though the lockfile is
# generated on macOS. See docs/deploy/coolify.md.
supported-architectures.os[]=current
supported-architectures.os[]=linux
supported-architectures.cpu[]=current
supported-architectures.cpu[]=x64
supported-architectures.cpu[]=arm64
